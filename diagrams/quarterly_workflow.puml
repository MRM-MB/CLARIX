@startuml Quarterly_Probabilistic_Capacity_Workflow
!theme plain
left to right direction
scale max 1400 width
skinparam backgroundColor #FEFEFE
skinparam ArrowColor #2C3E50
skinparam FontName Calibri
skinparam PackageBorderColor #2C3E50
skinparam PackageBackgroundColor #F0F0F0
skinparam DefaultFontSize 12
skinparam rectangle {
    BorderColor #2C3E50
    FontColor #FFFFFF
}

!define C_INPUT #1F77B4
!define C_QUALIFY #FF7F0E
!define C_TRANSLATE #2CA02C
!define C_FEASIBILITY #9467BD
!define C_ECONOMIC #8C564B
!define C_BOTTLENECK #D62728
!define C_DISRUPTION #7F7F7F
!define C_ACTION #17BECF

title Quarterly Probabilistic Capacity-and-Sourcing Workflow\n(Q1 Detailed, Q2-Q4 Condensed)

package "Q1 - Jan/Feb/Mar" as Q1_pkg #E8F4F8 {
    rectangle "Input Sales\nPipeline" as R1 C_INPUT
    rectangle "Qualify &\nPrioritize\nDemand" as R2 C_QUALIFY
    rectangle "Translate to\nProduction\nDemand" as R3 C_TRANSLATE
    rectangle "Check Material\nFeasibility" as R4 C_FEASIBILITY
    rectangle "Check Capacity\nFeasibility" as R5 C_FEASIBILITY
    rectangle "Check Logistics\nFeasibility" as R6 C_FEASIBILITY
    rectangle "Economic\nAssumptions" as R7 C_ECONOMIC
    rectangle "Identify\nBottlenecks\n& Risks" as R8 C_BOTTLENECK
    rectangle "Disruption\nScenarios" as R9 C_DISRUPTION
    rectangle "Recommend\nPlanner\nActions" as R10 C_ACTION
    
    R1 --> R2
    R2 --> R3
    R3 --> R4
    R3 --> R5
    R3 --> R6
    R4 --> R8
    R5 --> R8
    R6 --> R8
    R7 --> R8
    R8 --> R9
    R9 --> R10
}

package "Q2 - Apr/May/Jun" as Q2_pkg #E8F4F8 {
    rectangle "Condensed Repeat\nSame 10-step workflow\nUpdated forecast" as Q2_SUM #AAB7B8
}

package "Q3 - Jul/Aug/Sep" as Q3_pkg #E8F4F8 {
    rectangle "Condensed Repeat\nSame 10-step workflow\nRe-optimized plan" as Q3_SUM #AAB7B8
}

package "Q4 - Oct/Nov/Dec" as Q4_pkg #E8F4F8 {
    rectangle "Condensed Repeat\nSame 10-step workflow\nYear-end actions" as Q4_SUM #AAB7B8
}

R10 --> Q2_SUM : Quarterly Review
Q2_SUM --> Q3_SUM : Quarterly Review
Q3_SUM --> Q4_SUM : Quarterly Review
Q4_SUM --> R1 : Repeat Cycle\n(Next Year Q1)

legend left
    | Stage Group | Color | Notes |
    | Input | <#1F77B4>      | Sales pipeline |
    | Qualify | <#FF7F0E>    | Demand prioritization |
    | Translate | <#2CA02C>  | Production demand mapping |
    | Feasibility Checks | <#9467BD> | Material + Capacity + Logistics |
    | Economic | <#8C564B>   | Wage and energy assumptions |
    | Bottleneck | <#D62728> | Risk consolidation |
    | Disruption | <#7F7F7F> | Scenario testing |
    | Actions | <#17BECF>    | Planner recommendations |
    | Condensed Q2-Q4 | <#AAB7B8> | Same workflow, summarized |
endlegend

@enduml
