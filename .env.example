# Clarix - LLM agent backend keys
#
# Provide ONE of the following. The agent auto-detects which provider to use.
#
# 1) Anthropic Claude (default, preferred)
# ANTHROPIC_API_KEY=sk-ant-...
#
# 2) Google Gemini (fallback - works with the same tool-use loop)
# GEMINI_API_KEY=AIza...
#
# Optional: pick a non-default Gemini model
# GEMINI_MODEL=gemini-2.5-flash
